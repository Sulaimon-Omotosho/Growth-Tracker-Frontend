generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String        @id @default(uuid())
  email           String        @unique
  password        String?
  username        String?       @unique
  firstName       String?
  lastName        String?
  phone           String?
  gender          Gender?
  role            Role          @default(MEMBER)
  image           String?
  about           String?
  dob             DateTime?
  provider        String?
  providerId      String?
  addressId       String?
  districtId      String?
  communityId     String?
  zoneId          String?
  cellId          String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  accounts        Account[]
  leadsCell       Cell[]        @relation("CellLeader")
  leadsChurchTeam ChurchTeam[]  @relation("TeamPastor")
  leadsCommunity  Community[]   @relation("CommunityLeader")
  districtsLed    District[]    @relation("DistrictLeader")
  growthRecord    GrowthRecord?
  reports         Report[]      @relation("UserReports")
  sessions        Session[]
  address         Address?      @relation(fields: [addressId], references: [id])
  cell            Cell?         @relation(fields: [cellId], references: [id])
  community       Community?    @relation(fields: [communityId], references: [id])
  district        District?     @relation("DistrictUsers", fields: [districtId], references: [id])
  zone            Zone?         @relation(fields: [zoneId], references: [id])
  leadsZone       Zone[]        @relation("ZonalLeader")
  departments     Department[]  @relation("UserDepartments")
}

model Address {
  id      String  @id @default(uuid())
  street  String?
  city    String
  state   String
  country String
  zipCode String?
  users   User[]
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model District {
  id          String      @id @default(uuid())
  name        String
  leaderId    String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  communities Community[]
  leader      User?       @relation("DistrictLeader", fields: [leaderId], references: [id])
  users       User[]      @relation("DistrictUsers")
}

model Community {
  id         String   @id @default(uuid())
  name       String
  districtId String
  leaderId   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  cells      Cell[]
  district   District @relation(fields: [districtId], references: [id])
  leader     User?    @relation("CommunityLeader", fields: [leaderId], references: [id])
  users      User[]
  zones      Zone[]
}

model Zone {
  id          String    @id @default(uuid())
  name        String
  communityId String
  leaderId    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  cells       Cell[]
  users       User[]
  community   Community @relation(fields: [communityId], references: [id])
  leader      User?     @relation("ZonalLeader", fields: [leaderId], references: [id])
}

model Cell {
  id          String    @id @default(uuid())
  name        String
  zoneId      String
  communityId String
  leaderId    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  community   Community @relation(fields: [communityId], references: [id])
  leader      User?     @relation("CellLeader", fields: [leaderId], references: [id])
  zone        Zone      @relation(fields: [zoneId], references: [id])
  users       User[]
}

model ChurchTeam {
  id          String       @id @default(uuid())
  name        String
  description String?
  leaderId    String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  leader      User?        @relation("TeamPastor", fields: [leaderId], references: [id])
  departments Department[]
}

model Department {
  id           String     @id @default(uuid())
  name         String
  churchTeamId String
  email        String?
  description  String?
  leaderId     String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  churchTeam   ChurchTeam @relation(fields: [churchTeamId], references: [id])
  members      User[]     @relation("UserDepartments")
}

model DepTeam {
  id           String   @id @default(uuid())
  name         String
  departmentId String
  leaderId     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model GrowthRecord {
  id               String       @id @default(uuid())
  userId           String       @unique
  baptism          Boolean      @default(false)
  foundationCourse CourseStatus @default(NOT_STARTED)
  maturityCourse   CourseStatus @default(NOT_STARTED)
  joinedDepartment Boolean      @default(false)
  joinedCell       Boolean      @default(false)
  updatedAt        DateTime     @updatedAt
  user             User         @relation(fields: [userId], references: [id])
}

model Report {
  id         String     @id @default(uuid())
  title      String
  type       ReportType
  content    String
  authorId   String
  zoneId     String?
  districtId String?
  cellId     String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  author     User       @relation("UserReports", fields: [authorId], references: [id])
}

enum Role {
  CAMPUS_PASTOR
  PASTOR
  TEAM
  HOD
  DISTRICT
  ZONE
  CELL
  MEMBER
}

enum Gender {
  MALE
  FEMALE
}

enum ReportType {
  WEEKLY
  MONTHLY
}

enum CourseStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}
